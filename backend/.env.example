# ─── Server ───────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── Database ─────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=eld_dev
DB_USER=postgres
DB_PASSWORD=postgres

# ─── JWT ──────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=REPLACE_WITH_RANDOM_64_BYTE_HEX
JWT_REFRESH_SECRET=REPLACE_WITH_ANOTHER_RANDOM_64_BYTE_HEX

# Access token: short-lived (15 min for production, 1h for dev)
JWT_ACCESS_EXPIRES_IN=15m
# Refresh token: long-lived
JWT_REFRESH_EXPIRES_IN=30d

# ─── Security ─────────────────────────────────────
# Max failed login attempts before account lock
MAX_LOGIN_ATTEMPTS=5
# Lock duration in minutes
LOCK_DURATION_MINUTES=30

# ─── SMTP (for DOT Transfer email method) ─────────
# Leave SMTP_HOST empty to disable email sending (API returns stub response)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="ELD System" <noreply@your-carrier.example>

# ─── CORS ─────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:5174
